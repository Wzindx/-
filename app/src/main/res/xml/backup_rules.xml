<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Keep local prompts, generated image history and API/model configuration out of
         Android Auto Backup on pre-Android 12 devices. This mirrors data_extraction_rules.xml. -->
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
